<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:src="@drawable/funcup_logo"
        android:contentDescription="Logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:src="@drawable/funcup_logo"
        android:contentDescription="Logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Botão Excluir Histórico -->
    <ImageButton
        android:id="@+id/btnExcluirHistorico"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="18dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="Excluir Histórico"
        android:tint="#FF4444"
        app:layout_constraintBottom_toBottomOf="@id/imgLogo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/imgLogo" />

    <!-- Título -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMensagens"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"

        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintBottom_toTopOf="@id/layoutInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Resposta da IA -->
    <TextView
        android:id="@+id/txtResposta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="👋 Olá!\n\nSou a FanCup IA.\n\nEstou pronta para responder qualquer pergunta sobre o mercado de aposta Futebolístico."
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:lineSpacingExtra="8dp"
        android:padding="22dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintBottom_toTopOf="@id/layoutInferior"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Barra inferior -->
    <LinearLayout
        android:id="@+id/layoutInferior"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_margin="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/edtPergunta"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:background="@drawable/edittext_background"
            android:hint="Digite sua pergunta..."
            android:textColor="#FFFFFF"
            android:textColorHint="#8C8C8C"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <Space
            android:layout_width="12dp"
            android:layout_height="wrap_content"/>

        <ImageButton
            android:id="@+id/btnEnviar"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="@drawable/button_background"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:contentDescription="Enviar"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>