<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Barra superior: título + botão voltar -->
    <ImageButton
        android:id="@+id/btnVoltarGrupos"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="14dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:tint="#FFFFFF"
        android:contentDescription="Voltar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtTituloGrupos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="18dp"
        android:text="Grupos e Seleções"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnVoltarGrupos"
        app:layout_constraintBottom_toBottomOf="@id/btnVoltarGrupos"
        app:layout_constraintStart_toEndOf="@id/btnVoltarGrupos"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/edtBuscaGrupo"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/edittext_background"
        android:hint="Buscar seleção..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#8C8C8C"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/btnVoltarGrupos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        spanCount vem de res/values/integers.xml (1 coluna em telefones),
        res/values-sw600dp/integers.xml (2 colunas em tablets ~7")
        e res/values-sw840dp/integers.xml (3 colunas em tablets ~10")
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerGrupos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/edtBuscaGrupo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtVazioGrupos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="Nenhuma seleção encontrada."
        android:textColor="#8C8C8C"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/edtBuscaGrupo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
