  :root{
    --navy-dark:#1A2036;
    --navy-darker:#12172A;
    --orange:#F5A623;
    --bg-light:#F2F3F5;
    --card-white:#FFFFFF;
    --text-dark:#1A1A2E;
    --text-gray:#8A8FA3;
    --text-muted:#B5B9C7;
    --divider:#E7E9EE;
    --badge-bg:#F0F1F4;
    --chat-bg:#000000;
    --chat-ia:#1E1E1E;
    --chat-user:#2E7D32;
    --sidebar-w:230px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    background:var(--bg-light);
    color:var(--text-dark);
  }

  /* ---------- layout geral ---------- */
  .app{ display:flex; min-height:100vh; }

  .sidebar{
    width:var(--sidebar-w);
    background:var(--navy-dark);
    color:#fff;
    flex-shrink:0;
    padding:24px 0;
    position:fixed;
    top:0; left:0; bottom:0;
    display:flex;
    flex-direction:column;
  }
  .sidebar .logo{
    display:flex; align-items:center; gap:10px;
    padding:0 24px 28px 24px;
  }
  .sidebar .logo .globe{
    width:30px; height:30px; border-radius:8px;
    background:var(--navy-darker);
    display:flex; align-items:center; justify-content:center;
    font-size:14px;
  }
  .sidebar .logo .brand{ font-size:18px; font-weight:800; letter-spacing:.3px; }
  .sidebar .logo .brand span{ color:var(--orange); }

  .nav-item{
    display:flex; align-items:center; gap:12px;
    padding:12px 24px;
    color:var(--text-muted);
    cursor:pointer;
    font-size:14.5px;
    font-weight:600;
    border-left:3px solid transparent;
    transition:.15s;
  }
  .nav-item .ic{ width:18px; text-align:center; }
  .nav-item:hover{ color:#fff; background:rgba(255,255,255,.04); }
  .nav-item.active{
    color:var(--orange);
    background:rgba(245,166,35,.08);
    border-left:3px solid var(--orange);
  }

  .content{
    margin-left:var(--sidebar-w);
    flex:1;
    padding:32px 36px 60px 36px;
    max-width:1200px;
  }

  .page{ display:none; animation:fade .25s ease; }
  .page.active{ display:block; }
  @keyframes fade{ from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:none;} }

  h1.page-title{ font-size:26px; margin:0 0 4px 0; }
  p.page-sub{ color:var(--text-gray); margin:0 0 28px 0; font-size:14px; }

  /* ---------- cards genéricos ---------- */
  .card{
    background:var(--card-white);
    border-radius:16px;
    padding:20px;
  }
  .card + .card{ margin-top:16px; }
  .card h3{ margin:0 0 14px 0; font-size:16px; }

  .stats-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:16px;
    margin-bottom:16px;
  }
  .stat-card{ background:var(--card-white); border-radius:16px; padding:20px; }
  .stat-card .num{ font-size:28px; font-weight:800; }
  .stat-card .label{ color:var(--text-gray); font-size:13px; margin-top:2px; }

  .two-col{ display:grid; grid-template-columns:1.4fr 1fr; gap:16px; align-items:start; }

  table.tbl{ width:100%; border-collapse:collapse; }
  table.tbl th{
    text-align:center; font-size:11px; color:var(--text-gray);
    text-transform:uppercase; letter-spacing:.03em; padding:8px 4px;
    border-bottom:1px solid var(--divider);
  }
  table.tbl th:first-child{ text-align:left; }
  table.tbl td{ text-align:center; font-size:13.5px; padding:10px 4px; border-bottom:1px solid var(--divider); }
  table.tbl td:first-child{ text-align:left; font-weight:700; }
  table.tbl tr:last-child td{ border-bottom:none; }
  .classificado{ color:var(--orange); }

  .legend{ display:flex; align-items:center; gap:8px; margin-top:12px; font-size:12px; color:var(--text-gray); }
  .legend .dot{ width:10px; height:10px; border-radius:2px; background:var(--orange); }

  .player-row{ display:flex; align-items:center; gap:12px; padding:10px 0; }
  .player-row + .player-row{ border-top:1px solid var(--divider); }
  .badge{
    width:44px; height:44px; border-radius:10px; background:var(--badge-bg);
    display:flex; align-items:center; justify-content:center; font-weight:700; font-size:13px;
    flex-shrink:0;
  }
  .player-row .info{ flex:1; }
  .player-row .name{ font-weight:700; font-size:14px; }
  .player-row .sub{ color:var(--text-gray); font-size:12px; margin-top:1px; }
  .player-row .goals{ color:var(--orange); font-weight:800; font-size:18px; }

  /* ---------- estado de carregamento / placeholders ---------- */
  .toolbar{ display:flex; gap:10px; margin-bottom:18px; flex-wrap:wrap; }
  .toolbar select, .toolbar input{
    padding:10px 14px; border-radius:10px; border:1px solid var(--divider);
    font-size:13.5px; background:#fff; color:var(--text-dark);
  }
  .skeleton{
    background:linear-gradient(90deg,#eceef1 25%,#f5f6f8 37%,#eceef1 63%);
    background-size:400% 100%; animation:shine 1.4s ease infinite;
    border-radius:10px;
  }
  @keyframes shine{ 0%{background-position:100% 0;} 100%{background-position:0 0;} }
  .empty-state{ text-align:center; padding:40px 20px; color:var(--text-gray); font-size:14px; }

  .jogo-card{ display:flex; align-items:center; justify-content:space-between; padding:14px 4px; }
  .jogo-card + .jogo-card{ border-top:1px solid var(--divider); }
  .jogo-teams{ display:flex; align-items:center; gap:10px; font-weight:700; font-size:14px; }
  .jogo-placar{ font-weight:800; font-size:16px; color:var(--text-dark); }
  .jogo-meta{ font-size:12px; color:var(--text-gray); }
  .status-pill{ font-size:11px; font-weight:700; padding:4px 10px; border-radius:20px; }
  .status-encerrado{ background:var(--badge-bg); color:var(--text-gray); }
  .status-aovivo{ background:#FDECEC; color:#E53935; }
  .status-agendado{ background:#FFF4E0; color:var(--orange); }

  .grid-cards{ display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px; }
  .selecao-card{ border:1px solid var(--divider); border-radius:14px; padding:16px; text-align:center; }
  .selecao-card .flag{ font-size:34px; }
  .selecao-card .nome{ font-weight:700; margin-top:8px; }
  .selecao-card .grupo{ color:var(--text-gray); font-size:12px; margin-top:2px; }

  /* ---------- página IA (chat) ---------- */
  .ia-wrap{
    background:var(--chat-bg); border-radius:18px; overflow:hidden;
    display:flex; flex-direction:column; height:70vh;
  }
  .ia-header{ display:flex; align-items:center; gap:10px; padding:18px 20px; }
  .ia-header .globe{ width:34px; height:34px; border-radius:9px; background:#12172A; display:flex; align-items:center; justify-content:center; }
  .ia-header .txt{ color:#fff; font-weight:700; }
  .ia-header .txt span{ color:var(--orange); }
  .ia-messages{ flex:1; overflow-y:auto; padding:8px 20px; display:flex; flex-direction:column; gap:4px; }
  .bubble-row{ display:flex; padding:6px 0; }
  .bubble-row.ia{ justify-content:flex-start; }
  .bubble-row.user{ justify-content:flex-end; }
  .bubble{ max-width:75%; padding:13px 16px; border-radius:20px; color:#fff; font-size:14.5px; line-height:1.4; }
  .bubble.ia{ background:var(--chat-ia); }
  .bubble.user{ background:var(--chat-user); }
  .bubble.typing{ font-style:italic; color:var(--text-muted); background:var(--chat-ia); }
  .ia-inputbar{ display:flex; gap:10px; padding:16px 18px; }
  .ia-inputbar input{
    flex:1; height:50px; border-radius:30px; border:none; padding:0 20px;
    background:#171717; color:#fff; font-size:14px; outline:none;
  }
  .ia-inputbar input::placeholder{ color:#8C8C8C; }
  .ia-inputbar button{
    width:50px; height:50px; border-radius:50%; border:none; background:var(--orange);
    color:#12172A; font-size:18px; cursor:pointer; flex-shrink:0;
  }
  .ia-inputbar button:hover{ filter:brightness(1.05); }

  @media (max-width:900px){
    .sidebar{ display:none; }
    .content{ margin-left:0; padding:20px; }
    .stats-grid{ grid-template-columns:repeat(2,1fr); }
    .two-col{ grid-template-columns:1fr; }
  }
