<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageButton
        android:id="@+id/btnVoltarJogadores"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="14dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:tint="#FFFFFF"
        android:contentDescription="Voltar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtTituloJogadores"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="18dp"
        android:text="Jogadores"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btnVoltarJogadores"
        app:layout_constraintBottom_toBottomOf="@id/btnVoltarJogadores"
        app:layout_constraintStart_toEndOf="@id/btnVoltarJogadores"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Seletor de seleção -->
    <Spinner
        android:id="@+id/spinnerSelecao"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/edittext_background"
        android:popupBackground="#1A1A1A"
        android:spinnerMode="dropdown"
        app:layout_constraintTop_toBottomOf="@id/btnVoltarJogadores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Busca por nome de jogador -->
    <EditText
        android:id="@+id/edtBuscaJogador"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/edittext_background"
        android:hint="Buscar jogador..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#8C8C8C"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"
        app:layout_constraintTop_toBottomOf="@id/spinnerSelecao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        spanCount vem de res/values/integers.xml (1 coluna em telefones),
        res/values-sw600dp e res/values-sw840dp/integers.xml (2 e 3 colunas em tablets).
        Cabeçalhos de posição sempre ocupam a linha inteira (ver JogadoresActivity).
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerJogadores"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/edtBuscaJogador"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtVazioJogadores"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="Nenhum jogador encontrado."
        android:textColor="#8C8C8C"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/edtBuscaJogador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
